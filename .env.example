# Strict one-year backfill window.
DAYS_BACK=365

# Keep concurrency conservative so one source job finishes before the next starts.
MAX_CONCURRENCY=2
CRAWL_BATCH_SIZE=100
QUEUE_POLL_MS=5000
MIN_COVERAGE_MONTHS=12
MIN_ACCEPTED_ARTICLES=10
MIN_ACCEPTANCE_RATE=0.05

# Runtime database is intentionally outside Git. Crawlee queues are in-memory.
CRAWLER_DB_PATH=./data/crawler.db

# Discovery fails instead of silently accepting partial data at these caps.
MAX_SITEMAP_URLS=50000
MAX_SITEMAP_FILES=1000
MAX_SITEMAP_DEPTH=8
MAX_SITEMAP_DOWNLOAD_BYTES=52428800
MAX_SITEMAP_UNCOMPRESSED_BYTES=104857600
MAX_LISTING_REQUESTS=500
MAX_PAGINATION_LINKS_PER_PAGE=10

# Optional local classification service.
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=qwen3:8b
